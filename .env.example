# AI API 配置（必填）
# 申请地址：https://api.yunjunet.cn/console.html
# 创建 API Key 后填入下方
INTERNAL_API_SECRET=your_api_key_here

# 服务器配置
PORT=3022
NODE_ENV=production

# 存储路径（可选，默认 /home/ubuntu/imgbed-yunjunet-cn/storage）
# STORAGE_PATH=/home/ubuntu/imgbed-yunjunet-cn/storage

# 网站基础 URL（可选）
# BASE_URL=https://demo001.opensora2.cn
